{
	"schemaVersion": 1,
	"id": "create-cartels",
	"version": "${version}",
	"name": "Create: Cartels",
	"description": "Adds cartels into Minecraft and the ability to sell your products across the world",
	"authors": [
		"Alan Fine"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "MIT",
	"icon": "assets/create-cartels/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"net.createcartels.CreateCartels"
		],
		"client": [
			"net.createcartels.CreateCartelsClient"
		]
	},
	"mixins": [
		"create-cartels.mixins.json",
		{
			"config": "create-cartels.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.18.4",
		"minecraft": "~1.20.1",
		"java": ">=17",
		"fabric-api": "*",
		"create": ">=6.0.8.1"
	}
}